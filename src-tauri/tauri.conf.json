{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Usage Monitor",
  "version": "0.1.0",
  "identifier": "dev.jasonchen.claude-usage-monitor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Claude Usage Monitor",
        "width": 320,
        "height": 400,
        "resizable": false,
        "visible": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "resources": {
      "../scripts/claude-statusline-collector.cjs": "scripts/claude-statusline-collector.cjs"
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
